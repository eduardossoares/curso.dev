{
	"name": "bun-react-template",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --hot src/index.ts",
		"build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
		"start": "NODE_ENV=production bun src/index.ts",
		"lint": "bunx --bun @biomejs/biome check --write",
		"lint:fix:unsafe": "bunx --bun @biomejs/biome check --write --unsafe"
	},
	"dependencies": {
		"react": "^19",
		"react-dom": "^19"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@types/bun": "latest",
		"@types/react": "^19",
		"@types/react-dom": "^19"
	}
}
